# ====================================
# Server
# ====================================

PORT=3000

# ====================================
# NextAuth.js
# ====================================

# Secret for signing tokens (generate with: openssl rand -base64 32)
AUTH_SECRET=

# ====================================
# OAuth Providers
# ====================================

# GitHub OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ====================================
# Error Tracking
# ====================================

# Enable error tracking (set to "true" in production)
NEXT_PUBLIC_ERROR_TRACKING_ENABLED=false

# Error tracking service endpoint (optional)
# NEXT_PUBLIC_ERROR_TRACKING_ENDPOINT=https://your-error-tracking-service.com/api/errors

# Sentry DSN (if using Sentry)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# ====================================
# API Configuration
# ====================================

# Use local backend during development
NEXT_PUBLIC_USE_LOCAL_API=true
NEXT_PUBLIC_LOCAL_API_URL=http://localhost:3000/api/v1

# Production backend URL
NEXT_PUBLIC_PRODUCTION_API_URL=https://offer-hub-api-production.up.railway.app/api/v1
